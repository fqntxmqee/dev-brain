# === 飞书配置块（T-70） ===
# Brain 专用飞书应用（与 cc-connect 三 Bot 独立）
# 1) 访问 https://open.feishu.cn/app 创建企业自建应用
# 2) 权限：im:message, im:message.group_at_msg, im:message.p2p_msg, im:message:send_as_bot
# 3) 事件订阅：im.message.receive_v1, card.action.trigger
DEV_BRAIN_FEISHU_APP_ID=cli_xxx
DEV_BRAIN_FEISHU_APP_SECRET=your_app_secret

# 允许指挥的 open_id 列表（逗号分隔；* = 全部；空 = 拒绝所有）
# 查 open_id：飞书开放平台 → 调试工具 → 获取用户 open_id
DEV_BRAIN_ALLOW_FROM=ou_xxxxxxxxxxxxxxxxxxxxxxxx

# 飞书交互卡片（1=启用，0=仅文本）
DEV_BRAIN_FEISHU_CARDS=1
# 计划卡片审批按钮（1=启用；需订阅 card.action.trigger）
DEV_BRAIN_FEISHU_CARD_ACTIONS=1

# DEBUG 模式：打印 lark-cli event 原始行到 stderr
DEV_BRAIN_DEBUG=0
