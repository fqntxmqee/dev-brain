{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "ops" },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(rate(brain_tasks_completed[5m]))",
          "legendFormat": "completed/s",
          "refId": "A"
        }
      ],
      "title": "Brain Tasks Throughput",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.1 },
              { "color": "red", "value": 0.25 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(rate(brain_tasks_failed[5m])) / (sum(rate(brain_tasks_completed[5m])) + 0.001)",
          "legendFormat": "failure rate",
          "refId": "A"
        }
      ],
      "title": "Brain Task Failure Rate (5m)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 0 },
      "id": 3,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le) (rate(brain_task_duration_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(brain_task_duration_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(brain_task_duration_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "title": "Brain Task Duration (p50/p95/p99)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 6 },
      "id": 4,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(brain_subtask_duration_seconds_bucket[5m])))",
          "legendFormat": "subtask p95",
          "refId": "A"
        }
      ],
      "title": "Brain Subtask p95 Duration",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 6 },
      "id": 5,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(cc_send_duration_seconds_bucket[5m])))",
          "legendFormat": "cc-send p95",
          "refId": "A"
        }
      ],
      "title": "cc-connect Send p95",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "ops" },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 6 },
      "id": 6,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(adapter_sent[5m]))",
          "legendFormat": "sent/s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(adapter_failed[5m]))",
          "legendFormat": "failed/s",
          "refId": "B"
        }
      ],
      "title": "Adapter sent vs failed (5m)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "none" },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 6 },
      "id": 7,
      "options": { "colorMode": "value", "graphMode": "area" },
      "targets": [
        { "expr": "file_lock_held", "legendFormat": "held", "refId": "A" },
        {
          "expr": "sum(rate(file_lock_conflicts[5m]))",
          "legendFormat": "conflicts/s",
          "refId": "B"
        }
      ],
      "title": "File Lock Held & Conflicts",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "none" },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 12 },
      "id": 8,
      "options": { "colorMode": "value", "graphMode": "none" },
      "targets": [
        {
          "expr": "cc_socket_reachable",
          "legendFormat": "reachable",
          "refId": "A"
        }
      ],
      "title": "cc-connect Socket Reachable",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "bytes" },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 12 },
      "id": 9,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "process_heap_bytes", "legendFormat": "heap", "refId": "A" },
        { "expr": "process_rss_bytes", "legendFormat": "rss", "refId": "B" }
      ],
      "title": "Process Memory (heap / rss)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 12 },
      "id": 10,
      "options": { "colorMode": "value", "graphMode": "area" },
      "targets": [
        {
          "expr": "process_eventloop_lag_seconds",
          "legendFormat": "p99 lag",
          "refId": "A"
        }
      ],
      "title": "Event Loop Lag (p99)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 12 },
      "id": 11,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(http_metrics_requests[1m]))",
          "legendFormat": "/metrics",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_healthz_requests[1m]))",
          "legendFormat": "/healthz",
          "refId": "B"
        },
        {
          "expr": "sum(rate(http_readyz_requests[1m]))",
          "legendFormat": "/readyz",
          "refId": "C"
        }
      ],
      "title": "HTTP Request Rate by Endpoint",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "none" },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 18 },
      "id": 12,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "brain_pending_plans",
          "legendFormat": "pending",
          "refId": "A"
        },
        {
          "expr": "brain_active_tasks",
          "legendFormat": "active",
          "refId": "B"
        },
        {
          "expr": "brain_active_subtasks",
          "legendFormat": "subtasks",
          "refId": "C"
        }
      ],
      "title": "Brain Pending / Active",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
