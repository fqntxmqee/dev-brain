# Brain 专用飞书应用（与 cc-connect 三 Bot 独立）
DEV_BRAIN_FEISHU_APP_ID=cli_xxx
DEV_BRAIN_FEISHU_APP_SECRET=xxx
# 当前: cli_aaa841493a78dbb4 / CQktfxRkFAuU9h59Omd16f5sOHsBfqh4 (2026-06-05)

# 工作目录
DEV_BRAIN_WORK_DIR=/Users/fukai/workspace

# cc-connect Unix Socket
DEV_BRAIN_CC_CONNECT_SOCKET=/Users/fukai/.cc-connect/run/api.sock
DEV_BRAIN_CC_CONNECT_BIN=cc-connect
DEV_BRAIN_CC_DATA_DIR=/Users/fukai/.cc-connect

# cc-connect project 名称
DEV_BRAIN_CC_PROJECT_CLAUDE=workspace-claude
DEV_BRAIN_CC_PROJECT_CODEX=workspace-codex
DEV_BRAIN_CC_PROJECT_CURSOR=workspace-cursor

# stub = 离线 mock（Phase 1 默认）；live = 真实 cc-connect / Cursor SDK
DEV_BRAIN_ADAPTER_MODE=stub

# send = HTTP POST /send（异步确认）；relay = cc-connect relay send（同步文本，需 relay 绑定）
DEV_BRAIN_CC_SYNC=send
DEV_BRAIN_CC_RELAY_TIMEOUT_MS=300000

# 允许指挥的用户 open_id（逗号分隔，空=不限制）
DEV_BRAIN_ALLOW_FROM=

# 飞书交互卡片（1=启用，0=仅文本）
DEV_BRAIN_FEISHU_CARDS=1
# 计划卡片审批按钮（1=启用；需订阅 card.action.trigger 事件）
DEV_BRAIN_FEISHU_CARD_ACTIONS=1

# cc-connect Bridge 异步回复（live + send 模式；1=启用）
DEV_BRAIN_CC_BRIDGE=1
DEV_BRAIN_CC_BRIDGE_POLL_MS=2000
DEV_BRAIN_CC_BRIDGE_TIMEOUT_MS=300000
DEV_BRAIN_CC_BRIDGE_REPLY_PATH=/bridge/reply
DEV_BRAIN_CC_BRIDGE_SOCKET=/Users/fukai/.cc-connect/run/bridge.sock

# cc-connect 配置文件路径（migrate-headless / doctor 使用）
DEV_BRAIN_CC_CONFIG=/Users/fukai/.cc-connect/config.toml

# Cursor SDK（live 模式优先；未设置则 cursor 走 cc-connect workspace-cursor）
CURSOR_API_KEY=
DEV_BRAIN_CURSOR_MODEL=composer-2.5

# === v0.8.0: Native agent backend ===
# native     → 直接 spawn `claude` / `codex-minimax`（推荐，无 cc-connect 依赖）
# cc-connect → 老 UDS 派发路径（v0.7.0 行为）
DEV_BRAIN_AGENT_BACKEND=native

# === v0.8.0: Native Claude / Codex 高级配置（默认值已对齐 MiniMax） ===
# $MINIMAX_API_KEY 直接从环境透传（也可显式设 DEV_BRAIN_CLAUDE_API_KEY）
DEV_BRAIN_CLAUDE_BIN=claude
DEV_BRAIN_CLAUDE_BASE_URL=https://api.minimaxi.com/anthropic
DEV_BRAIN_CLAUDE_MODEL=MiniMax-M3-highspeed
DEV_BRAIN_CLAUDE_PERMISSION_MODE=bypassPermissions
DEV_BRAIN_CLAUDE_EXTRA_ARGS=

DEV_BRAIN_CODEX_BIN=codex-minimax
DEV_BRAIN_CODEX_PROFILE=m27
DEV_BRAIN_CODEX_BASE_URL=https://api.minimaxi.com/anthropic
DEV_BRAIN_CODEX_MODEL=MiniMax-M2.7-highspeed

DEV_BRAIN_NATIVE_TIMEOUT_MS=300000

# === v0.8.1: Cursor local CLI（native backend 优先走 cursor-agent） ===
# 可执行名: `cursor-agent`（新版）或 `agent`（兼容别名）
DEV_BRAIN_CURSOR_BIN=cursor-agent
# 鉴权: 留空用本地缓存的登录态；显式填 key 可走自定义 endpoint
# CURSOR_API_KEY=
# 模型: 留空走默认；可指定 sonnet-4 / gpt-5 / composer-2.5 等
DEV_BRAIN_CURSOR_MODEL=composer-2.5
# 模式: 空 = 默认（含写权限）；plan = 只读探索；ask = 只读 Q&A
# 推荐: dev-brain 探索子任务用 plan，后端/前端实现用空
DEV_BRAIN_CURSOR_MODE=plan

# === v0.8.0: Cursor fallback 策略 ===
# cc-connect = SDK 缺失时退回 cc-connect（默认）；error = 严格报错
DEV_BRAIN_CURSOR_FALLBACK=cc-connect
