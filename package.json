{
  "name": "dev-brain",
  "version": "0.4.0",
  "description": "飞书指挥的多 Agent 开发大脑 — 编排 Claude Code / Codex / Cursor",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/cli.ts",
    "start": "node dist/cli/cli.js",
    "cli": "tsx src/cli/cli.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "lint": "eslint src/ tests/",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'"
  },
  "bin": {
    "dev-brain": "./dist/cli/cli.js"
  },
  "keywords": [
    "dev-brain",
    "feishu",
    "cc-connect",
    "orchestration"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.3",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@cursor/sdk": "^1.0.17"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
